{
  "ConnectionStrings": {
    "Database": "Host=host.docker.internal;Port=5432;Database=expense-db;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft": "Information" }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "ServerUrl": "http://localhost:5341" } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Issuer": "auth-service",
    "Audience": "expense-tracker",
    "JwksUrl": "http://localhost:5100/.well-known/jwks"
  },
  "PermissionService": {
    "BaseUrl": "http://localhost:5200"
  },
  "RabbitMQ": {
    "Host": "host.docker.internal",
    "Port": 5672,
    "User": "guest",
    "Password": "guest"
  }
}
