{
  "ConnectionStrings": {
    "Database": "Host=host.docker.internal;Port=5432;Database=auth-db;Username=auth_app;Password=auth_app_pass;Include Error Detail=true"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "ServerUrl": "http://seq:5341" } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "PrivateKeyPath": "/workspace/keys/auth-private.pem",
    "PublicKeyPath": "/workspace/keys/auth-public.pem",
    "Issuer": "auth-service",
    "Audience": "expense-tracker",
    "ExpirationInMinutes": 60
  },
  "RabbitMQ": {
    "Host": "host.docker.internal",
    "Port": 5672,
    "User": "guest",
    "Password": "guest"
  }
}
