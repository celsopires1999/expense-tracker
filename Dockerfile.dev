FROM mcr.microsoft.com/dotnet/sdk:10.0

ARG USER_UID=1000
ARG USER_GID=1000
ARG DOCKER_GROUP_ID=999

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl && \
    install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc && \
    chmod a+r /etc/apt/keyrings/docker.asc && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential \
    docker-buildx-plugin \
    docker-ce-cli \
    docker-compose-plugin \
    git \
    gpg \
    gpg-agent \
    gnupg \
    libpq-dev \
    libssl-dev \
    pkg-config \
    socat && \
    rm -rf /var/lib/apt/lists/*

# Install just command runner and shell completions
RUN curl -fsSL https://github.com/casey/just/releases/download/1.51.0/just-1.51.0-x86_64-unknown-linux-musl.tar.gz -o /tmp/just.tar.gz && \
    tar -xzf /tmp/just.tar.gz -C /usr/local/bin just && \
    rm /tmp/just.tar.gz && \
    mkdir -p /etc/bash_completion.d /usr/local/share/zsh/site-functions && \
    just --completions bash > /etc/bash_completion.d/just && \
    just --completions zsh > /usr/local/share/zsh/site-functions/_just

RUN groupadd -f -g ${DOCKER_GROUP_ID} docker && \
    userdel -r ubuntu 2>/dev/null || true && \
    groupdel ubuntu 2>/dev/null || true && \
    groupadd -g ${USER_GID} developer && \
    useradd --uid ${USER_UID} --gid ${USER_GID} --create-home --shell /bin/bash developer && \
    usermod -aG docker developer

RUN mkdir -p /home/developer/.vscode-server && \
    chown -R developer:developer /home/developer/.vscode-server

ENV PATH="/home/developer/.dotnet/tools:${PATH}"

USER developer
RUN dotnet tool install --global dotnet-ef

ENTRYPOINT ["tail", "-f", "/dev/null"]
