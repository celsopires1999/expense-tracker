### ===========================================
# BASE URLS
# ===========================================
@authBaseUrl = http://localhost:5100
@permBaseUrl = http://localhost:5200
@expenseBaseUrl = http://localhost:5000

### Admin role GUID
@adminRoleId = 11111111-1111-1111-1111-111111111111

### Seeded category (Alimentação, available in clean DB)
@seededCategoryId = 33333333-3333-3333-3333-333333333333

### ===========================================
# AUTH SERVICE
# ===========================================

### Register User (auto-assigned Standard role)
# @name registerUser
POST {{authBaseUrl}}/auth/register
Content-Type: application/json

{
  "email": "john.doe@user.com",
  "firstName": "John",
  "lastName": "Doe",
  "password": "Str0ngP@ss!"
}

### Login (Standard user — only has read permissions on most resources)
# @name loginStandard
POST {{authBaseUrl}}/auth/login
Content-Type: application/json

{
  "email": "john.doe@user.com",
  "password": "Str0ngP@ss!"
}

### Get User by ID (requires users:access, which Standard has)
GET {{authBaseUrl}}/auth/users/{{registerUser.response.body.$}}
Authorization: Bearer {{loginStandard.response.body.token}}

### Assign Admin Role to user (requires auth — Standard token works)
POST {{authBaseUrl}}/auth/users/{{registerUser.response.body.$}}/roles/{{adminRoleId}}
Authorization: Bearer {{loginStandard.response.body.token}}

### Login again (token now includes Admin role — has full permissions)
# @name loginAdmin
POST {{authBaseUrl}}/auth/login
Content-Type: application/json

{
  "email": "john.doe@user.com",
  "password": "Str0ngP@ss!"
}

### Remove Admin Role (tests role removal with Admin token)
DELETE {{authBaseUrl}}/auth/users/{{registerUser.response.body.$}}/roles/{{adminRoleId}}
Authorization: Bearer {{loginAdmin.response.body.token}}

### Login again (token back to Standard only, after role removal)
# @name loginStandardAfter
POST {{authBaseUrl}}/auth/login
Content-Type: application/json

{
  "email": "john.doe@user.com",
  "password": "Str0ngP@ss!"
}

### Assign Admin Role back (so subsequent operations can create/edit/delete)
POST {{authBaseUrl}}/auth/users/{{registerUser.response.body.$}}/roles/{{adminRoleId}}
Authorization: Bearer {{loginStandardAfter.response.body.token}}

### Login final (Admin token for all remaining CRUD operations)
# @name loginAdminFinal
POST {{authBaseUrl}}/auth/login
Content-Type: application/json

{
  "email": "john.doe@user.com",
  "password": "Str0ngP@ss!"
}

###
@authToken = {{loginAdminFinal.response.body.token}}

### JWKS Public Key Set
GET {{authBaseUrl}}/.well-known/jwks

### ===========================================
# PERMISSION SERVICE
# ===========================================

### Create Role
# @name createRole
POST {{permBaseUrl}}/permissions/roles
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "Manager",
  "permissions": [
    "expenses:create",
    "expenses:read",
    "expenses:update",
    "expenses:delete",
    "categories:create",
    "categories:read",
    "categories:update",
    "categories:delete",
    "payment-methods:read",
    "tags:read",
    "users:access"
  ]
}

### List Roles
GET {{permBaseUrl}}/permissions/roles
Authorization: Bearer {{authToken}}

### Get Role by ID
GET {{permBaseUrl}}/permissions/roles/{{createRole.response.body.$}}
Authorization: Bearer {{authToken}}

### Update Role Permissions
PUT {{permBaseUrl}}/permissions/roles/{{createRole.response.body.$}}/permissions
Content-Type: application/json
Authorization: Bearer {{authToken}}

[
  "expenses:read",
  "categories:read",
  "payment-methods:read",
  "tags:read"
]

### Delete Role
DELETE {{permBaseUrl}}/permissions/roles/{{createRole.response.body.$}}
Authorization: Bearer {{authToken}}

### Resolve Permissions (used internally by Expense Service — no auth needed)
POST {{permBaseUrl}}/permissions/resolve
Content-Type: application/json

{
  "roles": ["Standard"]
}

### ===========================================
# EXPENSE SERVICE — Health
# ===========================================

### Health Check
GET {{expenseBaseUrl}}/health

### ===========================================
# EXPENSE SERVICE — Categories
# ===========================================

### Create Category (Admin permission: categories:create)
# @name createCategory
POST {{expenseBaseUrl}}/categories
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "Test Category"
}

### List Categories
GET {{expenseBaseUrl}}/categories
Authorization: Bearer {{authToken}}

### Update Category
PUT {{expenseBaseUrl}}/categories/{{createCategory.response.body.$}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "Updated Category"
}

### Delete Category
DELETE {{expenseBaseUrl}}/categories/{{createCategory.response.body.$}}
Authorization: Bearer {{authToken}}

### ===========================================
# EXPENSE SERVICE — Payment Methods
# ===========================================

### Create Payment Method (Admin permission: payment-methods:create)
# @name createPaymentMethod
POST {{expenseBaseUrl}}/payment-methods
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "Cartão de Crédito"
}

### List Payment Methods
GET {{expenseBaseUrl}}/payment-methods
Authorization: Bearer {{authToken}}

### Update Payment Method
PUT {{expenseBaseUrl}}/payment-methods/{{createPaymentMethod.response.body.$}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "Cartão de Crédito Visa"
}

### ===========================================
# EXPENSE SERVICE — Tags
# ===========================================

### Create Tag (Admin permission: tags:create)
# @name createTag
POST {{expenseBaseUrl}}/tags
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "urgente"
}

### List Tags
GET {{expenseBaseUrl}}/tags
Authorization: Bearer {{authToken}}

### Update Tag
PUT {{expenseBaseUrl}}/tags/{{createTag.response.body.$}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "prioridade"
}

### ===========================================
# EXPENSE SERVICE — Expenses
# ===========================================

### Create Expense (uses seeded category + created payment method + tag)
# Note: The seeded category "Alimentação" (33333333-...) is available
# in a clean database after running migrations.
# @name createExpense
POST {{expenseBaseUrl}}/expenses
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "description": "Supermercado",
  "amount": 150.50,
  "date": "2026-07-05",
  "categoryId": "{{seededCategoryId}}",
  "paymentMethodId": "{{createPaymentMethod.response.body.$}}",
  "tagIds": ["{{createTag.response.body.$}}"]
}

### List Expenses
GET {{expenseBaseUrl}}/expenses
Authorization: Bearer {{authToken}}

### List Expenses by User
GET {{expenseBaseUrl}}/expenses?userId={{registerUser.response.body.$}}
Authorization: Bearer {{authToken}}

### List Expenses by Date Range
GET {{expenseBaseUrl}}/expenses?from=2026-01-01&to=2026-12-31
Authorization: Bearer {{authToken}}

### List Expenses by Category
GET {{expenseBaseUrl}}/expenses?categoryId={{seededCategoryId}}
Authorization: Bearer {{authToken}}

### Get Expense by ID
GET {{expenseBaseUrl}}/expenses/{{createExpense.response.body.$}}
Authorization: Bearer {{authToken}}

### Update Expense
PUT {{expenseBaseUrl}}/expenses/{{createExpense.response.body.$}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "description": "Supermercado - Atualizado",
  "amount": 200.00,
  "date": "2026-07-05",
  "categoryId": "{{seededCategoryId}}",
  "paymentMethodId": "{{createPaymentMethod.response.body.$}}",
  "tagIds": ["{{createTag.response.body.$}}"]
}

### Delete Expense
DELETE {{expenseBaseUrl}}/expenses/{{createExpense.response.body.$}}
Authorization: Bearer {{authToken}}

### ===========================================
# CLEANUP — Delete created payment method and tag
# ===========================================

### Delete Payment Method
DELETE {{expenseBaseUrl}}/payment-methods/{{createPaymentMethod.response.body.$}}
Authorization: Bearer {{authToken}}

### Delete Tag
DELETE {{expenseBaseUrl}}/tags/{{createTag.response.body.$}}
Authorization: Bearer {{authToken}}

### ===========================================
# ERROR CASES
# ===========================================

### Get Expense — Not Found (expects 404)
GET {{expenseBaseUrl}}/expenses/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
Authorization: Bearer {{authToken}}
