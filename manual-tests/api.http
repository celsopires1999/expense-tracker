@baseUrl = http://host.docker.internal:8080
@token = {{loginUser.response.body.$}}

### ===========================================
# HEALTH
# ===========================================

### Health Check
GET {{baseUrl}}/health

### ===========================================
# USERS
# ===========================================

### Register User
# @name createUser
POST {{baseUrl}}/users/register
Content-Type: application/json

{
  "email": "john.doe@user.com",
  "firstName": "John",
  "lastName": "Doe",
  "password": "Str0ngP@ss!"
}

### Login
# @name loginUser
POST {{baseUrl}}/users/login
Content-Type: application/json

{
  "email": "john.doe@user.com",
  "password": "Str0ngP@ss!"
}

### Get User by ID (requires users:access permission)
GET {{baseUrl}}/users/{{createUser.response.body.$}}
Authorization: Bearer {{token}}

### ===========================================
# EXPENSES
# ===========================================

### Create Expense
# @name createExpense
POST {{baseUrl}}/expenses
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Supermercado",
  "amount": 150.50,
  "date": "2026-07-05",
  "categoryId": "33333333-3333-3333-3333-333333333333",
  "paymentMethodId": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
  "tagIds": []
}

### List Expenses
GET {{baseUrl}}/expenses
Authorization: Bearer {{token}}

### List Expenses by User
GET {{baseUrl}}/expenses?userId={{createUser.response.body.$}}
Authorization: Bearer {{token}}

### List Expenses by Date Range
GET {{baseUrl}}/expenses?from=2026-01-01&to=2026-12-31
Authorization: Bearer {{token}}

### List Expenses by Category
GET {{baseUrl}}/expenses?categoryId=33333333-3333-3333-3333-333333333333
Authorization: Bearer {{token}}

### Get Expense by ID
GET {{baseUrl}}/expenses/{{createExpense.response.body.$}}
Authorization: Bearer {{token}}

### Update Expense
PUT {{baseUrl}}/expenses/{{createExpense.response.body.$}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Supermercado - Atualizado",
  "amount": 200.00,
  "date": "2026-07-05",
  "categoryId": "33333333-3333-3333-3333-333333333333",
  "paymentMethodId": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
  "tagIds": []
}

### Delete Expense
DELETE {{baseUrl}}/expenses/{{createExpense.response.body.$}}
Authorization: Bearer {{token}}

### ===========================================
# CATEGORIES
# ===========================================

### List Categories
GET {{baseUrl}}/categories
Authorization: Bearer {{token}}

### ===========================================
# PAYMENT METHODS
# ===========================================

### List Payment Methods
GET {{baseUrl}}/payment-methods
Authorization: Bearer {{token}}

### ===========================================
# TAGS
# ===========================================

### List Tags
GET {{baseUrl}}/tags
Authorization: Bearer {{token}}

### ===========================================
# ERROR CASES
# ===========================================

### Get Expense - Not Found (expects 404)
GET {{baseUrl}}/expenses/{{$guid}}
Authorization: Bearer {{token}}
